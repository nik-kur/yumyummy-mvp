# Copy this file to ".env" and fill in your values.

# Base URL of the Phase 1 FastAPI backend (the same service the Telegram bot uses).
# Example: https://yumyummy-api.onrender.com
# Leave EMPTY to run the app entirely on built-in MOCK data — every screen works
# with no server, which is perfect for design review and Expo Go demos.
EXPO_PUBLIC_API_BASE_URL=

# Force mock data even when an API URL is set (uncomment for offline UI work):
# EXPO_PUBLIC_USE_MOCKS=1

# --- Adapty (in-app purchases / paywalls) --------------------------------
# Public SDK keys from Adapty dashboard → App settings → API keys.
# iOS key is also set in eas.json build profiles; set it here for local runs.
EXPO_PUBLIC_ADAPTY_IOS_SDK_KEY=
EXPO_PUBLIC_ADAPTY_ANDROID_SDK_KEY=
# Placement IDs (defaults: "main" / "onboarding"). Override only if renamed.
# EXPO_PUBLIC_ADAPTY_PLACEMENT_MAIN=main
# EXPO_PUBLIC_ADAPTY_PLACEMENT_ONBOARDING=onboarding

# --- PostHog (product analytics) -----------------------------------------
# Project API key from PostHog → Settings → Project. Without it, no events fire.
EXPO_PUBLIC_POSTHOG_API_KEY=
# EU cloud by default; override for US cloud or self-hosted.
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Sentry (crash / error reporting) ------------------------------------
# DSN for the yumyummy-mobile project. Without it, the app reports nothing.
EXPO_PUBLIC_SENTRY_DSN=
