{
  "expo": {
    "name": "YumYummy",
    "slug": "yumyummy-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yumyummy",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.yumyummy.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ai.yumyummy.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF5EC",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#B85A3A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "YumYummy uses your photos to log meals from pictures of your food.",
          "cameraPermission": "YumYummy uses the camera to log meals from photos of your food."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF5EC",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d466930c-0c2b-4540-91d5-3660bd3c8157"
      }
    },
    "owner": "yumyummy"
  }
}
