{
  "expo": {
    "name": "YumYummy",
    "slug": "yumyummy-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yumyummy",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.yumyummy.app",
      "appleTeamId": "WZAXY7M3G5",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork" },
          { "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork" },
          { "SKAdNetworkIdentifier": "238da6jt44.skadnetwork" },
          { "SKAdNetworkIdentifier": "22mmun2rn5.skadnetwork" },
          { "SKAdNetworkIdentifier": "4468km3ulz.skadnetwork" },
          { "SKAdNetworkIdentifier": "2u9pt9hc89.skadnetwork" },
          { "SKAdNetworkIdentifier": "hs6bdukanm.skadnetwork" },
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" },
          { "SKAdNetworkIdentifier": "424m5254lk.skadnetwork" },
          { "SKAdNetworkIdentifier": "4dzt52r2t5.skadnetwork" },
          { "SKAdNetworkIdentifier": "ludvb6z3bs.skadnetwork" }
        ]
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.ai.yumyummy.app"
        ]
      }
    },
    "android": {
      "package": "ai.yumyummy.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF5EC",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-secure-store", { "configureAndroidBackup": false }],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "YumYummy uses your photos to log meals from pictures of your food.",
          "cameraPermission": "YumYummy uses the camera to log meals from photos of your food."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF5EC",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "@react-native-community/datetimepicker",
      "@bacons/apple-targets",
      [
        "expo-audio",
        {
          "microphonePermission": "YumYummy uses the microphone so you can log meals by voice."
        }
      ],
      ["react-native-adapty", { "replaceAndroidBackupConfig": true }],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "YumYummy uses this to measure ad performance and improve your experience. Your data is never sold."
        }
      ],
      ["react-native-appsflyer", { "shouldUseStrictMode": false, "shouldUsePurchaseConnector": false }],
      ["expo-build-properties", { "ios": { "deploymentTarget": "15.1" } }],
      [
        "@sentry/react-native/expo",
        {
          "organization": "yumyummy",
          "project": "yumyummy-mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d466930c-0c2b-4540-91d5-3660bd3c8157"
      }
    },
    "owner": "yumyummy"
  }
}
